# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Backend API URL (API Gateway endpoint)
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com

# Streaming-annotate Function URL (separate Lambda with response streaming).
# Production/preview values are injected by the deploy workflow from the CDK
# `AnnotateStreamUrl` CloudFormation output. Local dev uses http://localhost:3002.
NEXT_PUBLIC_ANNOTATE_STREAM_URL=https://your-stream-hash.lambda-url.us-east-1.on.aws/
