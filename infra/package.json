{
  "name": "@language-drill/infra",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "diff": "cdk diff",
    "synth:prod": "cdk synth LanguageDrillStack --exclusively",
    "synth:dev": "cdk synth LanguageDrillStack-dev --exclusively",
    "deploy:prod": "cdk deploy LanguageDrillStack --exclusively --require-approval never",
    "deploy:dev": "cdk deploy LanguageDrillStack-dev --exclusively --require-approval never",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@language-drill/shared": "workspace:*",
    "aws-cdk-lib": "^2.251.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.1120.0",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
