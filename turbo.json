{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "@language-drill/db#build": {
      "dependsOn": ["@language-drill/shared#build"],
      "outputs": ["dist/**"]
    },
    "@language-drill/db#typecheck": {
      "dependsOn": ["@language-drill/shared#build"]
    },
    "@language-drill/db#test": {
      "dependsOn": ["@language-drill/shared#build", "@language-drill/ai#build"]
    }
  }
}
