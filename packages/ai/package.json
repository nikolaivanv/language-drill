{
  "name": "@language-drill/ai",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:frequency": "tsx scripts/build-frequency.ts",
    "build:vocab-lemma": "tsx scripts/build-vocab-lemma.ts",
    "bootstrap-prompts": "tsx scripts/bootstrap-prompts.ts",
    "push-prompts": "tsx scripts/push-prompts.ts",
    "eval:export": "tsx scripts/eval-export.ts",
    "eval:seed": "tsx scripts/eval-seed.ts",
    "eval": "tsx scripts/eval-run.ts",
    "eval:gen:export": "tsx scripts/eval-gen-export.ts",
    "eval:gen": "tsx scripts/eval-gen-run.ts",
    "propose:coverage-spec": "tsx scripts/propose-coverage-spec.ts",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@language-drill/db": "workspace:*",
    "@language-drill/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "langfuse": "^3.38.20",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
