{
  "name": "@language-drill/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "generate:exercises": "npx tsx scripts/generate-exercises.ts",
    "generate:theory": "npx tsx scripts/generate-theory.ts",
    "review:flagged": "npx tsx scripts/review-flagged.ts",
    "review:flagged-theory": "npx tsx scripts/review-flagged-theory.ts",
    "revalidate:cloze": "npx tsx scripts/revalidate-cloze-pool.ts",
    "seed:exercises": "npx tsx scripts/seed-exercises.ts",
    "cleanup:zombies": "npx tsx scripts/cleanup-zombie-jobs.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-sqs": "^3.1044.0",
    "@language-drill/ai": "workspace:*",
    "@language-drill/shared": "workspace:*",
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
