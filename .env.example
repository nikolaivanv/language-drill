# ============================================================
# Language Drill — Environment Variables
# ============================================================
# Copy this file to .env.local (for local development) and
# fill in the real values. Never commit .env.local to git.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the
# browser; all others are server-side only.
# ============================================================

# ------------------------------------------------------------
# Database (Neon serverless Postgres)
# ------------------------------------------------------------
# Connection string for the Neon database.
# Append ?pgbouncer=true for connection pooling in production.
# Example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb
DATABASE_URL=postgresql://user:password@host/dbname

# ------------------------------------------------------------
# Clerk Authentication
# ------------------------------------------------------------
# Server-side secret key — used in Lambda and Next.js server contexts.
# Find it at: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publishable key — used in Next.js server contexts (non-public).
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publishable key exposed to the browser via Next.js.
# Must match CLERK_PUBLISHABLE_KEY.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret — used to verify Clerk webhook payloads (svix).
# Find it at: https://dashboard.clerk.com → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Anthropic (Claude API)
# ------------------------------------------------------------
# API key for the Claude LLM (used by packages/ai and the Lambda).
# Find it at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Langfuse (LLM observability — Phase 1 read-only tracing)
# ------------------------------------------------------------
# Project keys for the Langfuse cloud project that receives traces
# from every Claude call in packages/ai. Local dev MUST point at the
# `language-drill-dev` project — never the production one — so your
# local debugging does not pollute prod dashboards (Req 8.3).
#
# Find them at:
#   https://cloud.langfuse.com → Project Settings → API Keys
#
# Leave BOTH unset to disable tracing entirely (Req 1 AC 2 — the
# wrapper falls back to a vanilla Anthropic client with zero added
# latency or behaviour change). Useful for offline dev / CI / tests.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxx

# Optional: override the Langfuse cloud endpoint (e.g. for a future
# self-hosted instance). Defaults to https://cloud.langfuse.com.
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional (web, admin): Langfuse traces-list URL template for the admin
# "View traces in Langfuse" deep-link. Capture a tag-filtered traces URL from
# your Langfuse project UI (filter on tag cellKey=<any cell>), then replace the
# cell value with the literal {cellKey} placeholder. Unset → the link is hidden.
# NEXT_PUBLIC_LANGFUSE_TRACE_URL_TEMPLATE=https://cloud.langfuse.com/project/<projectId>/traces?filter=<...>{cellKey}<...>

# Optional: sample rate in [0, 1]. Default 1.0 (trace everything).
# Drop to e.g. 0.1 on the `generate` Lambda only if Phase-1 volume
# threatens the 25k traces/month operational target.
# LANGFUSE_SAMPLE_RATE=1.0

# ------------------------------------------------------------
# Langfuse prompt registry (Phase 2)
# ------------------------------------------------------------
# Optional overrides for the in-process prompt cache that backs the
# `getPromptOrFallback` / `getPromptWithVarsOrFallback` helpers in
# packages/ai/src/prompts-registry.ts.
#
# LANGFUSE_PROMPT_CACHE_TTL_MS — how long a fetched prompt is reused
# before re-checking Langfuse. Default 300000 (5 min). Lower values
# pick up `production`-label flips faster at the cost of more API
# calls; higher values are cheaper but slower to react. The Lambda
# cold-start eviction is independent of this knob.
# LANGFUSE_PROMPT_CACHE_TTL_MS=300000
#
# LANGFUSE_PROMPT_FETCH_TIMEOUT_MS — per-request budget for a Langfuse
# fetch before we fall back to the in-repo string. Default 250 ms.
# Keep this tight — a slow Langfuse must not delay the Claude call;
# falling back is the safer behaviour.
# LANGFUSE_PROMPT_FETCH_TIMEOUT_MS=250

# ------------------------------------------------------------
# Upstash Redis (rate limiting + caching — Phase 1)
# ------------------------------------------------------------
# Placeholder — Upstash Redis is introduced in Phase 1 when the
# first AI-facing routes are added. Leave blank locally for Phase 0.
# Find it at: https://console.upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token

# ------------------------------------------------------------
# AWS
# ------------------------------------------------------------
# AWS region where the CDK stack is deployed.
# Must match the region used when running `cdk bootstrap`.
AWS_REGION=us-east-1

# Phase 4 — SQS queue URL for the generation pipeline. Set this when using
# `pnpm generate:exercises --queue`. Find the value in the CDK stack outputs
# (`GenerationQueueUrl`) after `cdk deploy`.
# GENERATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/LanguageDrillStack-dev-GenerationQueue-XXXXX

# Admin access (comma-separated Clerk user IDs allowed to call /admin/* routes).
#
# Local Lambda dev server (pnpm dev:api) reads this directly. Default value
# matches the dev_user_001 injected by infra/lambda/src/dev.ts.
#
# For deployed environments, the same name is used at CDK synth time:
#   ADMIN_USER_IDS      → baked into the prod Lambda (LanguageDrillStack)
#   ADMIN_USER_IDS_DEV  → baked into the dev Lambda  (LanguageDrillStack-dev)
# Both are wired through GitHub Actions secrets in .github/workflows/deploy.yml.
ADMIN_USER_IDS=dev_user_001
# ADMIN_USER_IDS_DEV=user_2abc...

# ------------------------------------------------------------
# API (Next.js → Lambda)
# ------------------------------------------------------------
# Base URL of the deployed API Gateway endpoint.
# For local development, point this at a local Lambda emulator or
# a deployed dev/staging API Gateway URL.
# Example (production): https://abc123.execute-api.us-east-1.amazonaws.com
NEXT_PUBLIC_API_URL=https://api.example.com

# ------------------------------------------------------------
# Sentry (frontend error tracking — apps/web only)
# ------------------------------------------------------------
# Scope: browser + Next.js server/edge runtime errors in apps/web.
# Lambda errors continue to land in CloudWatch; LLM traces continue
# to land in Langfuse. See `.claude/specs/sentry-error-tracking/`.

# Public DSN for the browser + server + edge SDKs. Exposed to the
# browser by design — Sentry DSNs are embedded in clients.
# Local dev MUST point at a development Sentry project — never the
# production one — so your debugging does not pollute the prod
# issues inbox (same rule as Langfuse above). Leave blank locally
# to disable Sentry entirely (the SDK becomes a no-op).
# Find it at: https://sentry.io → Settings → Projects → <project> → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Server-only build-time token used by withSentryConfig to upload
# source maps during `next build` on Vercel. NOT exposed to the
# browser — no NEXT_PUBLIC_ prefix.
# Find/create at: https://sentry.io → Settings → Auth Tokens
# (scopes: project:releases, project:write)
SENTRY_AUTH_TOKEN=

# Sentry org and project slugs (consumed by withSentryConfig for
# source-map upload). Optional locally; set in Vercel for prod and
# preview environments.
SENTRY_ORG=
SENTRY_PROJECT=

# Vercel system vars exposed to the browser bundle. Vercel does NOT
# auto-expose VERCEL_ENV / VERCEL_GIT_COMMIT_SHA to client code — only
# NEXT_PUBLIC_* prefixed vars are inlined by Next.js's DefinePlugin.
# Without these, every browser-side Sentry event would be tagged
# `environment: development` regardless of where it actually ran.
# Set both in Vercel as "shared" values referencing the system vars:
#   NEXT_PUBLIC_VERCEL_ENV              = $VERCEL_ENV
#   NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA   = $VERCEL_GIT_COMMIT_SHA
# Locally, leave both blank — resolvers fall back to development.
NEXT_PUBLIC_VERCEL_ENV=
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=
